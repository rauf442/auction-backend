{
  "name": "backend",
  "version": "1.0.0",
  "description": "MSABER Admin Panel Backend",
  "main": "dist/index.js",
  "scripts": {
    "predev": "bash ../scripts/sync-supabase.sh",
    "prestart": "echo 'Skipping Supabase sync in production - use manual sync if needed'",
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:backend": "bash ../scripts/kill-ports.sh 3001 && nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup:storage": "ts-node src/scripts/setup-storage.ts",
    "migrate:drive-urls": "node ../scripts/migrate-drive-image-urls.js",
    "change-password": "ts-node src/scripts/change-superadmin-password.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.48.0",
    "@swc/helpers": "^0.5.17",
    "@types/archiver": "^6.0.3",
    "@types/multer": "^2.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "@types/pdfkit": "^0.17.2",
    "@types/socket.io": "^3.0.1",
    "archiver": "^7.0.1",
    "basic-ftp": "^5.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fast-xml-parser": "^5.4.1",
    "googleapis": "^156.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.15",
    "multer": "^2.0.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.10.1",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.15.2",
    "sharp": "^0.34.2",
    "socket.io": "^4.8.1",
    "stripe": "^18.4.0",
    "tslib": "^2.8.1",
    "xero-node": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.11",
    "@types/papaparse": "^5.5.2",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0"
  }
}
